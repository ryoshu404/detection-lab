ES_URL=

ES_API_KEY=

TINES_WEBHOOK_URL=

# Alerts index/alias to read (default is fine)
ALERTS_INDEX=.alerts-security.alerts-default

# State file location on the VM
STATE_FILE=/var/lib/alert-poller/state.json

# Re-query window (minutes) to catch out-of-order alerts; dedup handles overlap
OVERLAP_MINUTES=5

# Optional: path to the ES CA cert for TLS verification.
# Leave empty to skip verification (lab-acceptable with self-signed cert).
ES_CA_CERT=
