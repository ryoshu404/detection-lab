[Unit]
Description=Push new Elastic detection alerts to Tines
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/etc/alert-poller/config.env
ExecStart=/usr/bin/python3 /opt/alert-poller/alert_poller.py
User=alert-poller
Group=alert-poller
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/alert-poller
PrivateTmp=true
